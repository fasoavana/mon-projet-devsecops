PROJECT_NAME=SecureTask
API_V1_STR=/api/v1

# Change this in production!
SECRET_KEY=a_very_strong_and_long_secret_key_that_is_at_least_32_bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=43200 # 30 days

# PostgreSQL
POSTGRES_SERVER=db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=securetask_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_TIMES=5
RATE_LIMIT_SECONDS=60
